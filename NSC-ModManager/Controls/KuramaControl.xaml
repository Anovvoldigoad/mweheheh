<UserControl x:Class="NSC_ModManager.Controls.KuramaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NSC_ModManager.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!--
            CATATAN (lihat AUDIT_LOG.md bagian 6l): style KuramaTailAnimation/_2/_3
            DULU pakai <Storyboard><DoubleAnimation ... RepeatBehavior="Forever"
            AutoReverse="True"/></Storyboard> lewat Style.Triggers (IsEnabled=True).
            Ini DIHAPUS dan diganti animasi manual via DispatcherTimer di
            KuramaControl.xaml.cs (lihat method StartTailAnimations) - method WPF
            internal yang menangani animasi periodik ini
            (System.Windows.Media.Animation.TimeIntervalCollection.
            ProjectOntoPeriodicFunction) TERBUKTI dari crash_log.txt +
            log Wine jadi sumber NullReferenceException/native
            ACCESS_VIOLATION berulang di WinNative. RenderTransform tetap
            RotateTransform biasa (cuma di-drive manual, bukan via WPF
            Storyboard/Clock), jadi hasil visualnya identik.
        -->
        <!--
            FIX (lihat AUDIT_LOG.md bagian 6m): RotateTransform TIDAK LAGI di-set
            lewat Style Setter di sini. Style di WPF itu di-seal (immutable) begitu
            dipakai kali pertama, dan Setter.Value yang berupa Freezable (spt
            RotateTransform) ikut di-FREEZE saat itu juga - jadi SATU instance yang
            sama dipakai bersama oleh semua Image yang pakai Style ini, dan sudah
            read-only. Makanya `t.Transform.Angle = ...` di code-behind selalu
            lempar InvalidOperationException ("read-only state") di SETIAP start
            app (lihat crash_log.txt: "Cannot set a property on object
            'System.Windows.Media.RotateTransform'..."), yang selama ini keliru
            diklasifikasikan sebagai "framework-internal/bug Wine" dan diredam
            diam-diam - padahal ini bug app sendiri, dan akibatnya animasi ekor
            Kurama TIDAK PERNAH benar-benar jalan. RotateTransform sekarang
            dideklarasikan langsung per-Image di bawah (bukan lewat Style), supaya
            tiap Image dapat instance sendiri yang independen & tidak frozen.
        -->
        <Style x:Key="NoChromeButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="Chrome" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Height"
                                                From="220"
                                                To="210"
                                                Duration="0:0:0.1"
                                                AutoReverse="True"/>    
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </UserControl.Resources>
    <Grid MaxHeight="300" MinHeight="200">
        <Image Height="180" Width="150" Stretch="Uniform" x:Name="KuramaTailImage_3" Source="{DynamicResource ResourceKey=KuramaTail_4}" RenderOptions.BitmapScalingMode="HighQuality" Panel.ZIndex="0" RenderTransformOrigin="0.501,0.848" Margin="0,-60,0,0">
            <Image.RenderTransform>
                <RotateTransform/>
            </Image.RenderTransform>
        </Image>
        <Image Height="180" Width="150" Stretch="Uniform" x:Name="KuramaTailImage_2" Source="{DynamicResource ResourceKey=KuramaTail_3}" RenderOptions.BitmapScalingMode="HighQuality" Panel.ZIndex="0" RenderTransformOrigin="0.937,0.675" Margin="-116,0,0,-27">
            <Image.RenderTransform>
                <RotateTransform/>
            </Image.RenderTransform>
        </Image>
        <Button Style="{StaticResource NoChromeButton}"  Panel.ZIndex="10" Height="220" Width="220" >
            <Image Stretch="Uniform" x:Name="KuramaBodyImage" Source="{DynamicResource ResourceKey=KuramaBody}" RenderOptions.BitmapScalingMode="HighQuality" Panel.ZIndex="1"/>

        </Button>
        <Image Height="180" Width="150" Stretch="Uniform" x:Name="KuramaTailImage" Source="{DynamicResource ResourceKey=KuramaTail_2}" RenderOptions.BitmapScalingMode="HighQuality" Panel.ZIndex="0" RenderTransformOrigin="0.008,0.708" Margin="0,0,-145,-24">
            <Image.RenderTransform>
                <RotateTransform/>
            </Image.RenderTransform>
        </Image>
        
    </Grid>
</UserControl>
