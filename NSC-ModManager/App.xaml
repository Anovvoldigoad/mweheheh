<Application x:Class="NSC_ModManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NSC_ModManager"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"  
             xmlns:xcdg="http://schemas.xceed.com/wpf/xaml/datagrid"
             StartupUri="View/TitleView.xaml"  Startup="App_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Font kustom "CC2 RocknRoll Latin DB" di Resources/Fonts/Storm4_rus.ttf.
                 Riwayat percobaan:
                 1) "Resources/Fonts/#..." relatif -> UriFormatException di Winlator.
                 2) Ganti ke font sistem "Arial" -> TETAP UriFormatException (jadi
                    bukan soal font custom vs sistem).
                 3) "pack://application:,,,/Resources/Fonts/Storm4_rus.ttf#..." (pack URI
                    + nama file eksplisit) -> TETAP gagal. Ternyata syntax ini SALAH:
                    aturan WPF untuk font resource, bagian sebelum # harus FOLDER, bukan
                    nama file - menyertakan nama file bikin WPF gagal mem-parse-nya
                    sebagai referensi resource lalu diam-diam fallback ke pencarian
                    font SISTEM (match persis dgn PhysicalFontFamily di stack trace crash).
                 4) FIX: pack URI ke FOLDER saja (tanpa nama file), sesuai dokumentasi
                    resmi WPF. -->
            <FontFamily x:Key="NarutoFont">pack://application:,,,/Resources/Fonts/#CC2 RocknRoll Latin DB</FontFamily>

            <ResourceDictionary.MergedDictionaries>
                <!-- ModernWpf (ui:ThemeResources / ui:XamlControlsResources) sudah dilepas.
                     Fluent/Mica composition theme itu yang paling sering bikin WPF app
                     black-screen atau crash di Winlator. Diganti WinlatorStyle.xaml,
                     style flat berbasis Border/Trigger biasa. -->
                <ResourceDictionary Source="Resources/Styles/WinlatorStyle.xaml" />
                <ResourceDictionary Source="Resources/Styles/LightStyle.xaml" />
                <ResourceDictionary Source="Resources/Localization/lang.xaml" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
