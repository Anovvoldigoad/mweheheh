<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        WinlatorStyle.xaml
        ===================
        Pengganti ModernWpf/Fluent Design (ThemeResources + XamlControlsResources).

        Kenapa ini perlu:
        ModernWpf/WinUI-style controls (Mica/Acrylic backdrop, komposisi Fluent,
        animasi berbasis compositor) bergantung pada DWM/WinRT composition API
        Windows 10/11 asli. Di Winlator (Wine di atas Android), API tersebut
        sering tidak diimplementasikan penuh -> hasilnya window hitam/transparan,
        crash saat startup, atau kontrol tidak ter-render sama sekali.

        Style di bawah ini murni vector/brush WPF klasik (Border, Path, Trigger
        properti biasa - tanpa Storyboard/Composition), jadi cocok untuk
        render tier rendah / software rendering yang dipakai Winlator.
    -->

    <!-- ===================== PALET WARNA DASAR ===================== -->
    <Color x:Key="Win_BgColor">#1E1E22</Color>
    <Color x:Key="Win_PanelColor">#2A2A30</Color>
    <Color x:Key="Win_AccentColor">#C97A2B</Color>
    <Color x:Key="Win_AccentColorHover">#E08F3C</Color>
    <Color x:Key="Win_BorderColor">#4A4A52</Color>
    <Color x:Key="Win_TextColor">#F0F0F0</Color>
    <Color x:Key="Win_DisabledColor">#6A6A70</Color>

    <SolidColorBrush x:Key="Win_BgBrush" Color="{StaticResource Win_BgColor}"/>
    <SolidColorBrush x:Key="Win_PanelBrush" Color="{StaticResource Win_PanelColor}"/>
    <SolidColorBrush x:Key="Win_AccentBrush" Color="{StaticResource Win_AccentColor}"/>
    <SolidColorBrush x:Key="Win_AccentHoverBrush" Color="{StaticResource Win_AccentColorHover}"/>
    <SolidColorBrush x:Key="Win_BorderBrush" Color="{StaticResource Win_BorderColor}"/>
    <SolidColorBrush x:Key="Win_TextBrush" Color="{StaticResource Win_TextColor}"/>
    <SolidColorBrush x:Key="Win_DisabledBrush" Color="{StaticResource Win_DisabledColor}"/>

    <!-- ===================== WINDOW DEFAULT ===================== -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Win_BgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
        <!-- WindowChrome kustom sengaja TIDAK dipakai: caption bar bawaan Windows
             lebih stabil di Wine/Winlator dibanding custom titlebar transparan. -->
    </Style>

    <!-- ===================== BUTTON (flat, no shadow/blur) ===================== -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Win_PanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Win_BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Win_AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Win_AccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Win_DisabledBrush}"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== TEXTBOX ===================== -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Win_PanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Win_TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Win_BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== COMBOBOX (dipakai apa adanya dari default Aero,
         cukup restyle warna dasarnya via SystemColors agar tidak putih polos) ===================== -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Win_PanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Win_BorderBrush}"/>
    </Style>

    <!-- ===================== CHECKBOX toggle biasa ===================== -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
    </Style>

    <!-- ===================== TOGGLESWITCH STYLE (pengganti ui:ToggleSwitch) =====================
         Dibangun dari CheckBox biasa. Murni Border + Ellipse + Trigger properti,
         TANPA Storyboard/animasi compositor - aman untuk software rendering. -->
    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Track" Width="40" Height="20" CornerRadius="10"
                                Background="{StaticResource Win_PanelBrush}"
                                BorderBrush="{StaticResource Win_BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Ellipse x:Name="Thumb" Width="14" Height="14" Fill="{StaticResource Win_TextBrush}"
                                         HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            </Grid>
                        </Border>
                        <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource Win_AccentBrush}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource Win_DisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== DATAGRID ===================== -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource Win_BgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
        <Setter Property="RowBackground" Value="{StaticResource Win_BgBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource Win_PanelBrush}"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="BorderBrush" Value="{StaticResource Win_BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource Win_PanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="BorderBrush" Value="{StaticResource Win_BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <!-- ===================== TABCONTROL ===================== -->
    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{StaticResource Win_PanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
    </Style>
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource Win_BgBrush}"/>
    </Style>

    <!-- ===================== SCROLLBAR (versi flat sederhana) ===================== -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource Win_BgBrush}"/>
    </Style>

    <!-- ===================== LISTBOX ===================== -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource Win_BgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Win_BorderBrush}"/>
    </Style>

    <!-- ===================== GROUPBOX / LABEL ===================== -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Win_BorderBrush}"/>
    </Style>
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource Win_TextBrush}"/>
    </Style>

</ResourceDictionary>
